FROM python:3.9-slim

WORKDIR /app

# Install dependencies
COPY pyproject.toml .
RUN pip install --no-cache-dir -e .

# Copy source code
COPY src/ src/

# Create data directory
RUN mkdir -p /app/data

EXPOSE 8000

CMD ["uvicorn", "memo_agent.api.app:create_app", "--host", "0.0.0.0", "--port", "8000", "--factory"]
